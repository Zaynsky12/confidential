{
  "rewrites": [
    {
      "source": "/docs",
      "destination": "/docs/index.html"
    },
    {
      "source": "/docs/",
      "destination": "/docs/index.html"
    },
    {
      "source": "/docs/:path*",
      "destination": "/docs/:path*.html"
    },
    {
      "source": "/((?!docs).*)",
      "destination": "/index.html"
    }
  ]
}
